# Copy this file to .env and fill in your own values.
# NEVER commit .env to version control — it is listed in .gitignore.

# Supabase project URL (Settings > API)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase project reference ID (found in the URL above)
VITE_SUPABASE_PROJECT_ID=your-project-ref

# Supabase publishable key — safe to expose in the browser
# (Settings > API > Project API keys > Publishable key)
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key-here

# Supabase anon key (legacy JWT format) — used by Edge Functions via Deno.env
# Keep this out of browser bundles; only needed for local Supabase CLI / edge functions
SUPABASE_ANON_KEY=your-anon-jwt-key-here

# Supabase service role key — KEEP THIS SECRET, never expose in the browser
# (Settings > API > Project API keys > service_role)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here