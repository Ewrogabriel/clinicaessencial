# Copy this file to .env and fill in your own values.
# NEVER commit .env to version control — it is listed in .gitignore.

# Supabase project URL (Settings > API)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase project reference ID (found in the URL above)
VITE_SUPABASE_PROJECT_ID=your-project-ref

# Supabase anon/public key (Settings > API > Project API keys > anon public)
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-public-key-here

# Supabase service role key — KEEP THIS SECRET, never expose in the browser
# (Settings > API > Project API keys > service_role)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here